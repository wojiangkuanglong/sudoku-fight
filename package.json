{
  "name": "sudoku-fight",
  "private": true,
  "packageManager": "pnpm@10.32.1",
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run build --filter=@sudoku-fight/shared && concurrently -n server,web -c blue,green \"pnpm --filter @sudoku-fight/server dev\" \"pnpm --filter @sudoku-fight/web dev\"",
    "lint": "ultracite check",
    "format": "ultracite fix",
    "check": "ultracite check && turbo run typecheck",
    "typecheck": "turbo run typecheck",
    "taze": "pnpm dlx taze -r",
    "prepare": "husky",
    "clean": "turbo run clean && rimraf node_modules .turbo dist"
  },
  "lint-staged": {
    "*.{js,jsx,ts,tsx,mjs,cjs,json,jsonc,css}": "ultracite fix"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.8",
    "concurrently": "^9.2.1",
    "husky": "^9.1.7",
    "lint-staged": "^16.4.0",
    "taze": "^19.10.0",
    "turbo": "^2.8.20",
    "typescript": "catalog:",
    "ultracite": "^7.3.2"
  }
}
